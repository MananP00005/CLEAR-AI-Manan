# Get a free key at https://console.groq.com/keys
# Multiple comma-separated keys are supported for rotation when one hits its
# free-tier rate limit (e.g. yours + a teammate's).
GROQ_API_KEYS=your_groq_api_key_here

# Where per-participant chat transcripts are written (one .txt file per ID).
CHAT_LOGS_DIR=chat_logs

# Origins allowed to call this API. In Docker, nginx proxies same-origin so
# this doesn't matter there -- it's for local dev (Vue on 5173 -> FastAPI on 8000).
ALLOWED_ORIGINS=http://localhost:5173
